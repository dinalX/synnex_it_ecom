generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String
  categoryId  String?
  sortOrder   Int      @default(0)
  price       Int
  compareAt   Int?
  rating      Float    @default(5)
  inventory   Int      @default(0)
  sku         String?  @unique
  image       String
  accent      String   @default("#1f8a70")
  description String
  shortDescription String?
  specs       String
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryRef ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images      ProductImage[]
  variants    ProductVariant[]
  orderItems  OrderItem[]
  cartItems   CartItem[]
  wishlistItems WishlistItem[]
  inventoryTransactions InventoryTransaction[]
  heroBanners HeroBanner[]
  homeSectionItems HomeSectionItem[]

  @@index([categoryId])
  @@index([published])
  @@index([sortOrder])
}

model Order {
  id                String   @id @default(cuid())
  orderNumber       String   @unique
  customerId        String?
  assignedAdminId   String?
  customer          String
  email             String?
  phone             String?
  status            String   @default("Pending")
  paymentMode       String   @default("Offline")
  paymentStatus     String   @default("AwaitingUpload")
  fulfillmentStatus String   @default("Unfulfilled")
  subtotal          Int      @default(0)
  discountTotal     Int      @default(0)
  shippingTotal     Int      @default(0)
  total             Int
  currency          String   @default("LKR")
  notes             String?
  billingAddress    String?
  shippingAddress   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customerAccount Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignedAdmin   AdminUser?      @relation("AssignedOrders", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  paymentUploads  PaymentUpload[]
  inventoryTransactions InventoryTransaction[]

}

model ProductCategory {
  id               String   @id @default(cuid())
  parentId         String?
  updatedById      String?
  slug             String   @unique
  path             String?  @unique
  name             String
  shortDescription String?
  description      String?
  imageUrl         String?
  imageAlt         String?
  bannerImageUrl   String?
  icon             String?
  accent           String   @default("#1f8a70")
  seoTitle         String?
  seoDescription   String?
  canonicalUrl     String?
  sortOrder        Int      @default(0)
  featured         Boolean  @default(false)
  published        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  parent    ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  ProductCategory[] @relation("ProductCategoryTree")
  updatedBy AdminUser?        @relation("ProductCategoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  products  Product[]

  @@index([parentId])
  @@index([updatedById])
  @@index([published])
  @@index([featured])
  @@index([sortOrder])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sortOrder])
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  sku         String   @unique
  name        String
  optionName  String?
  optionValue String?
  price       Int
  compareAt   Int?
  inventory   Int      @default(0)
  imageUrl    String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems CartItem[]
  orderItems OrderItem[]
  wishlistItems WishlistItem[]
  inventoryTransactions InventoryTransaction[]

  @@index([productId])
  @@index([active])
  @@index([sortOrder])
}

model Customer {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  phone        String?
  passwordHash String?
  status       String    @default("Active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  addresses      CustomerAddress[]
  orders         Order[]
  paymentUploads PaymentUpload[]
  carts          Cart[]
  wishlists      Wishlist[]

  @@index([status])
}

model CustomerAddress {
  id         String  @id @default(cuid())
  customerId String
  label      String  @default("Default")
  recipient  String
  phone      String?
  line1      String
  line2      String?
  city       String
  district   String?
  postalCode String?
  country    String  @default("Sri Lanka")
  isDefault  Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String?
  variantId   String?
  sku         String?
  name        String
  quantity    Int
  unitPrice   Int
  lineTotal   Int
  productData String?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  inventoryTransactions InventoryTransaction[]

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model Cart {
  id         String   @id @default(cuid())
  customerId String?
  sessionId  String?  @unique
  status     String   @default("Active")
  currency   String   @default("LKR")
  subtotal   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  expiresAt  DateTime?

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([customerId])
  @@index([status])
  @@index([expiresAt])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int
  unitPrice Int
  lineTotal Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, variantId])
  @@index([productId])
  @@index([variantId])
}

model Wishlist {
  id         String    @id @default(cuid())
  customerId String?
  name       String?   @default("Default")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    WishlistItem[]

  @@index([customerId])
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String?
  variantId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  wishlist Wishlist        @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product  Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant  ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([wishlistId, productId, variantId])
  @@index([productId])
  @@index([variantId])
}

model InventoryTransaction {
  id         String   @id @default(cuid())
  productId  String
  variantId  String?
  orderId    String?
  orderItemId String?
  adminId    String?
  type       String
  reason     String?
  quantity   Int
  beforeQty  Int?
  afterQty   Int?
  note       String?
  createdAt  DateTime @default(now())

  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  order     Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItem OrderItem?      @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  admin     AdminUser?      @relation("InventoryChangedBy", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
  @@index([orderId])
  @@index([orderItemId])
  @@index([adminId])
  @@index([type])
  @@index([createdAt])
}

model PaymentUpload {
  id           String    @id @default(cuid())
  orderId      String
  customerId   String?
  verifiedById String?
  method       String    @default("BankTransfer")
  status       String    @default("PendingReview")
  reference    String?
  amount       Int?
  currency     String    @default("LKR")
  fileName     String
  fileUrl      String
  fileMimeType String?
  fileSize     Int?
  customerNote String?
  adminNote    String?
  uploadedAt   DateTime  @default(now())
  verifiedAt   DateTime?

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  verifiedBy AdminUser? @relation("PaymentVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([customerId])
  @@index([verifiedById])
  @@index([status])
  @@index([uploadedAt])
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         String    @default("Admin")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  assignedOrders    Order[]           @relation("AssignedOrders")
  verifiedPayments  PaymentUpload[]   @relation("PaymentVerifiedBy")
  auditLogs         AdminAuditLog[]
  productCategories ProductCategory[] @relation("ProductCategoryUpdatedBy")
  blogPosts         BlogPost[]        @relation("BlogPostAuthor")
  reviewedBlogPosts BlogPost[]        @relation("BlogPostReviewer")
  uploadedBlogMedia BlogMedia[]
  seoProfiles       SeoProfile[]      @relation("SeoProfileUpdatedBy")
  seoRoutes         SeoRoute[]        @relation("SeoRouteUpdatedBy")
  seoRedirects      SeoRedirect[]     @relation("SeoRedirectUpdatedBy")
  inventoryTransactions InventoryTransaction[] @relation("InventoryChangedBy")
  permissions           AdminPermission[]      @relation("AdminPermissions")
  permissionsGranted    AdminPermission[]      @relation("PermissionsGrantedBy")
  paymentGatewayConfigs PaymentGatewayConfig[]
  createdHeroBanners    HeroBanner[]
  passwordResetTokens   AdminPasswordResetToken[] @relation("AdminPasswordResetTokens")
  notifications         AdminNotification[]       @relation("AdminNotifications")

  @@index([role])
  @@index([active])
}

model AdminPermission {
  id          String   @id @default(cuid())
  adminId     String
  key         String
  grantedAt   DateTime @default(now())
  grantedById String?

  admin     AdminUser  @relation("AdminPermissions", fields: [adminId], references: [id], onDelete: Cascade)
  grantedBy AdminUser? @relation("PermissionsGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([adminId, key])
  @@index([adminId])
  @@index([key])
}

model AdminPasswordResetToken {
  id        String    @id @default(cuid())
  adminId   String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  admin AdminUser @relation("AdminPasswordResetTokens", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
}

model AdminNotification {
  id        String    @id @default(cuid())
  adminId   String
  type      String
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  admin AdminUser @relation("AdminNotifications", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, readAt])
  @@index([createdAt])
}

model PaymentGatewayConfig {
  id              String   @id @default(cuid())
  provider        String   @unique
  enabled         Boolean  @default(false)
  mode            String   @default("sandbox")
  merchantId      String?
  secretEncrypted String?
  extraConfig     String?
  updatedById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  updatedBy AdminUser? @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([provider])
  @@index([enabled])
}

model BlogPost {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  excerpt         String?
  body            String
  status          String    @default("Draft")
  featured        Boolean   @default(false)
  authorId        String?
  reviewedById    String?
  categoryId      String?
  featuredImageId String?
  seoTitle        String?
  seoDescription  String?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  author        AdminUser?    @relation("BlogPostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  reviewedBy    AdminUser?    @relation("BlogPostReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  category      BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  featuredImage BlogMedia?    @relation("BlogPostFeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull)
  media         BlogMedia[]   @relation("BlogPostMedia")
  tags          BlogPostTag[]

  @@index([authorId])
  @@index([reviewedById])
  @@index([categoryId])
  @@index([featuredImageId])
  @@index([status])
  @@index([featured])
  @@index([publishedAt])
}

model BlogCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts BlogPost[]

  @@index([published])
  @@index([sortOrder])
}

model BlogTag {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())

  posts BlogPostTag[]
}

model BlogPostTag {
  postId String
  tagId  String

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

model BlogMedia {
  id           String   @id @default(cuid())
  postId       String?
  uploadedById String?
  fileName     String
  fileUrl      String
  mimeType     String
  size         Int?
  width        Int?
  height       Int?
  alt          String?
  caption      String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  post             BlogPost?  @relation("BlogPostMedia", fields: [postId], references: [id], onDelete: Cascade)
  uploadedBy       AdminUser? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  featuredForPosts BlogPost[] @relation("BlogPostFeaturedImage")

  @@index([postId])
  @@index([uploadedById])
  @@index([createdAt])
  @@index([sortOrder])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String?
  action    String
  entity    String
  entityId  String?
  metadata  String?
  ipAddress String?
  createdAt DateTime @default(now())

  admin AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model SeoProfile {
  id                 String   @id @default(cuid())
  key                String   @unique
  siteName           String
  siteUrl            String
  defaultTitle       String
  titleTemplate      String?
  defaultDescription String?
  defaultKeywords    String?
  defaultImageUrl    String?
  defaultImageAlt    String?
  twitterHandle      String?
  twitterCard        String   @default("summary_large_image")
  robotsIndex        Boolean  @default(true)
  robotsFollow       Boolean  @default(true)
  sitemapEnabled     Boolean  @default(true)
  robotsTxt          String?
  organizationJsonLd String?
  updatedById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  updatedBy AdminUser? @relation("SeoProfileUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedById])
}

model SeoRoute {
  id                String   @id @default(cuid())
  path              String   @unique
  entityType        String?
  entityId          String?
  title             String?
  description       String?
  keywords          String?
  canonicalUrl      String?
  imageUrl          String?
  imageAlt          String?
  robotsIndex       Boolean  @default(true)
  robotsFollow      Boolean  @default(true)
  includeInSitemap  Boolean  @default(true)
  sitemapPriority   Float?
  sitemapChangefreq String?
  structuredData    String?
  status            String   @default("Active")
  updatedById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  updatedBy AdminUser? @relation("SeoRouteUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([updatedById])
  @@index([status])
  @@index([includeInSitemap])
}

model SeoRedirect {
  id          String   @id @default(cuid())
  sourcePath  String   @unique
  targetUrl   String
  statusCode  Int      @default(301)
  active      Boolean  @default(true)
  notes       String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updatedBy AdminUser? @relation("SeoRedirectUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([active])
  @@index([updatedById])
}

model PageContent {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  summary        String
  body           String
  seoTitle       String?
  seoDescription String?
  published      Boolean  @default(true)
  updatedAt      DateTime @updatedAt
}

model JobPost {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  department   String
  location     String
  type         String
  summary      String
  requirements String
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DriverDownload {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  deviceType String
  version    String
  os         String
  fileUrl    String
  notes      String
  published  Boolean  @default(true)
  updatedAt  DateTime @updatedAt
}

model PaymentInstruction {
  id           String  @id @default(cuid())
  method       String  @unique
  title        String
  instructions String
  enabled      Boolean @default(true)
  sortOrder    Int     @default(0)
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  group     String   @default("general")
  updatedAt DateTime @updatedAt
}

model HeroBanner {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  imageUrl    String
  imageAlt    String?
  ctaLabel    String?
  ctaHref     String?
  productId   String?
  theme       String   @default("light")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product   Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdBy AdminUser? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([active])
  @@index([sortOrder])
  @@index([productId])
}

model HomeSectionItem {
  id        String   @id @default(cuid())
  section   String
  productId String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([section, productId])
  @@index([section])
  @@index([sortOrder])
}
